<% layout("/layout/boilerplate") %>

    <h3>All listing</h3>
    <!-- <form method="GET" action="/listing/new"><Button>Create new Listing</Button></form> -->

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
      <% for(let lists of allListing){ %>
        <a href="/listing/<%= lists._id  %>" class="lists-link">  
      <div class="card col listing-card">
      <img src="<%= lists.image.url || '/images/default.jpg' %>" class="card-img-top" alt="listing_image" style="height:20rem; width:20rem"/>
       <div class="card-img-overlay"></div>
      <div class="card-body">
        <p class="card-text"><b><%= lists.title %></b><br/>
          <%= lists.price.toLocaleString("en-IN") %> / night
        </p>
      </div>
       </div>
       </a>
       <% } %>
    </div>
    

  


